# Brevo (emails) — plan gratuito 300 mails/día, sin dominio propio.
# Setup: crear cuenta en https://app.brevo.com, verificar un single sender
# (email de Valen) desde Settings > Senders & IP, y generar una API key
# en Settings > SMTP & API > API Keys.
BREVO_API_KEY=xkeysib-your-api-key
FROM_EMAIL=valencosovschi@hotmail.com
FROM_NAME=COSOV.
ADMIN_EMAIL=valencosovschi@hotmail.com
